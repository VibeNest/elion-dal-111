# --- gRPC ---
GRPC_HOST=0.0.0.0
GRPC_PORT=50051

# --- Сервер REST API: где слушать (на проде: 0.0.0.0:8080) ---
ADMIN_HOST=0.0.0.0
ADMIN_PORT=8080

# --- Доступ к API ручкам (Bearer-токен) ---
# Клиент шлёт: Authorization: Bearer <token>. Пусто => проверка выключена.
# Можно переопределять в админке (app_settings.api_token).
API_TOKEN=

# --- Локальная админка (отдельный процесс, HTTP-клиент к серверу) ---
# Базовый URL сервера, напр. https://elion-dal.vibenest.net (без хвостового /).
API_BASE_URL=
# Опциональный Basic-auth локальной админки (если хочется защитить даже на localhost).
ADMIN_USER=admin
ADMIN_PASSWORD=

# --- (Зарезервировано под gRPC — сейчас отключён, см. ADR-006) ---
GRPC_TARGET=
GRPC_INSECURE=false

# --- Qdrant ---
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=elion_chunks
# Устойчивость к транзиентным сбоям Qdrant (сетевые/IO):
QDRANT_TIMEOUT_S=10.0          # таймаут http-клиента (сек), чтобы зависший Qdrant не вешал запрос
QDRANT_RETRY_ATTEMPTS=3        # всего попыток на сетевой вызов (1 = без ретраев)
QDRANT_RETRY_BASE_DELAY_S=0.5  # база экспоненциального backoff (сек)
# Размер окна embed+upsert при индексации (большие документы пишутся батчами):
UPSERT_BATCH_SIZE=256

# --- Postgres (source-of-truth) ---
# Внутри docker compose host = "postgres"; локально = "localhost"
PG_DSN=postgresql+psycopg://elion:elion@localhost:5432/elion
# Создавать схему при старте (create_all, идемпотентно). false => миграции через alembic.
AUTO_MIGRATE=true

# --- Эмбеддинги ---
# Бэкенд (по итогам исследования leaderboard — рекомендуется st-bm25):
#   st-bm25   -> dense deepvk/USER-bge-m3 (sentence-transformers) + BM25 sparse; лучший конфиг (R@5 0.98)
#   fastembed -> ONNX multilingual-e5-large + BM25 (легче/быстрее на CPU, R@5 0.92)
#   flag      -> настоящий BGE-M3 dense + learned sparse; требует pip install -e ".[flag]"
EMBEDDING_BACKEND=st-bm25
# Пусто => дефолтная модель бэкенда. Для st-bm25 dense — deepvk/USER-bge-m3.
EMBEDDING_MODEL=deepvk/USER-bge-m3
# EMBEDDING_DIM больше не обязателен: размерность определяется по самой модели.
# Оставлен как необязательная подсказка/фоллбэк.
EMBEDDING_DIM=1024
# int8-квантизация модели. ВНИМАНИЕ: для flag/BGE-M3 (torch dynamic int8) RSS по замерам
# НЕ снижается (~удваивается на пике) — default false. Реальная экономия RAM = int8 ONNX.
EMBEDDING_QUANTIZE=false

# --- Чанкинг (рекомендуемый конфиг: recursive 1024/102, structured) ---
CHUNK_TOKENS=1024
CHUNK_OVERLAP=102
# Мин. размер чанка в токенах: 0 = выкл; >0 => чанки короче дропаются при индексации
# (фильтр мусора — заголовки-сироты, хвосты-обрезки). Можно менять в админке (live).
CHUNK_MIN_TOKENS=0
# Стратегия сепараторов нарезки: structured (абзацы→предложения→слова) | token (жёстко
# по абзац/строка/слово/символ). Можно менять в админке (live).
CHUNK_SEPARATOR_MODE=structured
# Токенайзер для подсчёта длины чанков (не зависит от EMBEDDING_MODEL)
CHUNK_TOKENIZER_MODEL=BAAI/bge-m3

# --- Поиск ---
SEARCH_TOP_K=3
# Кол-во кандидатов на каждую ветку prefetch перед RRF-fusion
SEARCH_PREFETCH=20
# Во сколько раз больше детей тянуть, чтобы схлопнуть в top_k уникальных родителей
SEARCH_PARENT_FANOUT=5

# --- Приоритет свежести ---
# 0 = выкл; >0 => множитель к скору по дате публикации (приоритет 2026/2027)
RECENCY_WEIGHT=0.0
RECENCY_HALFLIFE_DAYS=365
