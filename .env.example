# --- gRPC ---
GRPC_HOST=0.0.0.0
GRPC_PORT=50051

# --- Веб-админка (в том же процессе, что и gRPC) ---
ADMIN_ENABLED=true
ADMIN_HOST=0.0.0.0
ADMIN_PORT=8080
# Basic-auth админки. Пустой ADMIN_PASSWORD => auth выключен (только для dev!).
ADMIN_USER=admin
ADMIN_PASSWORD=

# --- Доступ к gRPC API (ручкам) ---
# Фиксированный токен; клиент шлёт его в metadata (authorization: Bearer <token> | x-api-token).
# Пусто => проверка выключена. Можно переопределить в админке (app_settings.api_token).
API_TOKEN=

# --- Qdrant ---
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=elion_chunks

# --- Postgres (source-of-truth) ---
# Внутри docker compose host = "postgres"; локально = "localhost"
PG_DSN=postgresql+psycopg://elion:elion@localhost:5432/elion
# Создавать схему при старте (create_all, идемпотентно). false => миграции через alembic.
AUTO_MIGRATE=true

# --- Эмбеддинги ---
# Бэкенд выбирается по итогам бенча (bench/benchmark_embeddings.py):
#   fastembed -> ONNX multilingual-e5-large (быстро на CPU, ставится из коробки)
#   flag      -> настоящий BGE-M3 dense + learned sparse (вариант A по ТЗ);
#                требует доп. зависимость: pip install -e ".[flag]"
EMBEDDING_BACKEND=fastembed
# Пусто => дефолтная модель бэкенда (fastembed: intfloat/multilingual-e5-large; flag: BAAI/bge-m3)
EMBEDDING_MODEL=
# EMBEDDING_DIM больше не обязателен: размерность определяется по самой модели.
# Оставлен как необязательная подсказка/фоллбэк.
EMBEDDING_DIM=1024
# int8-квантизация модели. ВНИМАНИЕ: для flag/BGE-M3 (torch dynamic int8) RSS по замерам
# НЕ снижается (~удваивается на пике) — default false. Реальная экономия RAM = int8 ONNX.
EMBEDDING_QUANTIZE=false

# --- Чанкинг ---
CHUNK_TOKENS=400
CHUNK_OVERLAP=64
# Токенайзер для подсчёта длины чанков (не зависит от EMBEDDING_MODEL)
CHUNK_TOKENIZER_MODEL=BAAI/bge-m3

# --- Поиск ---
SEARCH_TOP_K=3
# Кол-во кандидатов на каждую ветку prefetch перед RRF-fusion
SEARCH_PREFETCH=20
# Во сколько раз больше детей тянуть, чтобы схлопнуть в top_k уникальных родителей
SEARCH_PARENT_FANOUT=5

# --- Реранкер (опционально) ---
# true => переупорядочивать родителей cross-encoder'ом (требует .[flag], ~600 МБ, +латентность)
RERANK_ENABLED=false
RERANK_MODEL=BAAI/bge-reranker-v2-m3

# --- Приоритет свежести ---
# 0 = выкл; >0 => множитель к скору по дате публикации (приоритет 2026/2027)
RECENCY_WEIGHT=0.0
RECENCY_HALFLIFE_DAYS=365
